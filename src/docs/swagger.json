{
  "openapi": "3.0.0",
  "info": {
    "title": "VyaparIQ API",
    "version": "1.0.0",
    "description": "API documentation for VyaparIQ SaaS Platform"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "API v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" },
                  "role": { "type": "string", "enum": ["SUPER_ADMIN", "BUSINESS_OWNER", "MANAGER", "STAFF"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Successfully created user" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successfully authenticated" }
        }
      }
    },
    "/users/me": {
      "get": {
        "tags": ["Users"],
        "summary": "Get current user profile",
        "responses": {
          "200": { "description": "User profile" }
        }
      },
      "patch": {
        "tags": ["Users"],
        "summary": "Update user profile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated" }
        }
      }
    },
    "/businesses/me": {
      "get": {
        "tags": ["Businesses"],
        "summary": "Get my business",
        "responses": {
          "200": { "description": "Business profile" },
          "404": { "description": "Not found" }
        }
      },
      "patch": {
        "tags": ["Businesses"],
        "summary": "Update my business",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Business updated" }
        }
      }
    },
    "/businesses": {
      "post": {
        "tags": ["Businesses"],
        "summary": "Create a new business",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "gstin": { "type": "string" },
                  "type": { "type": "string" },
                  "address": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Business created" }
        }
      }
    }
  }
}
